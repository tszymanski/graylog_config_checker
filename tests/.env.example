# Graylog test environment configuration
# Copy to .env and fill in the values, or run: make setup

# Shared secret for password encryption (min 64 chars, same value for graylog and datanode)
# Generate with: < /dev/urandom tr -dc A-Z-a-z-0-9 | head -c96; echo
GRAYLOG_PASSWORD_SECRET=

# SHA-256 hash of the Graylog root (admin) password
# Default below is hash of "admin" - change for non-local environments
# Generate with: echo -n "yourpassword" | sha256sum | cut -d" " -f1
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# Admin password in plain text - used only by Makefile targets to call the API
GRAYLOG_ROOT_PASSWORD=admin

# Optional: override image versions
# GRAYLOG_IMAGE=graylog/graylog:7.1
# DATANODE_IMAGE=graylog/graylog-datanode:7.1
